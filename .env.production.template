# ============================================
# PumpFun Production Environment Configuration
# ============================================
# Copy this file to .env.production and fill in ALL values.
# NEVER commit .env.production to version control.
#
# Generate a secure NEXTAUTH_SECRET with:
#   openssl rand -base64 32
#
# Generate a strong Postgres password with:
#   openssl rand -hex 24

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# The 'db' hostname resolves to the Postgres container inside Docker.
# Change CHANGE_ME_STRONG_PASSWORD to a long random string.
DATABASE_URL=postgresql://pumpfun:CHANGE_ME_STRONG_PASSWORD@db:5432/pumpfun
POSTGRES_USER=pumpfun
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=pumpfun

# ---------------------------------------------------------------------------
# NextAuth — Authentication
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=GENERATE_ME
NEXTAUTH_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# Solana RPC
# ---------------------------------------------------------------------------
# DO NOT use the public Solana RPC endpoint in production — it will rate-limit
# you heavily. Get a dedicated endpoint from:
#   - Helius:   https://helius.dev
#   - QuickNode: https://quicknode.com
#   - Triton:   https://triton.one
SOLANA_RPC_URL=https://your-rpc-url.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc-url.com
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# ---------------------------------------------------------------------------
# Platform
# ---------------------------------------------------------------------------
# Treasury wallet — receives platform fees
PLATFORM_WALLET_ADDRESS=CfyjfkdfVchdvtKyPbBxBoScfSUPBVMwnGbYeXBs5uKw
PLATFORM_FEE_PERCENT=1
GRADUATION_THRESHOLD_SOL=85
# Fee in basis points (100 bps = 1%)
NEXT_PUBLIC_PLATFORM_FEE_BPS=100

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.com
UPLOAD_DIR=./public/uploads

# ---------------------------------------------------------------------------
# Docker image (set by CI/CD; override for manual deploys)
# ---------------------------------------------------------------------------
APP_IMAGE=ghcr.io/ghost69-321/pumpfun:latest

# ---------------------------------------------------------------------------
# Domain — used by deploy.sh for Nginx and SSL configuration
# ---------------------------------------------------------------------------
DOMAIN=your-domain.com
